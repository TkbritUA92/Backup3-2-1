<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Enterprise 3-2-1 Data Protection Architecture Lab</title>
    <style>
        :root {
            --bg-dark: #0b0f19;
            --panel-bg: #131c2e;
            --node-bg: #1e293b;
            --accent-blue: #0ea5e9;
            --accent-purple: #a855f7;
            --accent-green: #22c55e;
            --accent-orange: #f97316;
            --accent-red: #ef4444;
            --text-light: #f8fafc;
            --text-muted: #64748b;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-light);
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
        }

        .lab-wrapper {
            width: 100%;
            max-width: 1400px;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        header {
            background-color: var(--panel-bg);
            padding: 20px;
            border-radius: 12px;
            border: 1px solid #1e293b;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .header-info h1 {
            margin: 0 0 8px 0;
            font-size: 1.8rem;
            color: var(--accent-blue);
        }

        .header-info p {
            margin: 0;
            color: var(--text-muted);
            font-size: 0.95rem;
        }

        .workspace-grid {
            display: grid;
            grid-template-columns: 340px 1fr 340px;
            gap: 20px;
        }

        .panel {
            background-color: var(--panel-bg);
            border: 1px solid #1e293b;
            border-radius: 12px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .panel-title {
            font-size: 1rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #94a3b8;
            border-bottom: 2px solid #1e293b;
            padding-bottom: 8px;
            margin-bottom: 5px;
        }

        .data-token {
            background: linear-gradient(135deg, #0284c7, #0369a1);
            color: white;
            padding: 12px;
            border-radius: 6px;
            cursor: grab;
            font-weight: 600;
            text-align: center;
            box-shadow: 0 4px 6px rgba(0,0,0,0.2);
            border: 1px solid #0c4a6e;
        }

        .setting-control {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .setting-control label {
            font-size: 0.85rem;
            font-weight: 600;
            color: #cbd5e1;
        }

        select, input[type="range"] {
            width: 100%;
            background-color: var(--bg-dark);
            border: 1px solid #334155;
            color: white;
            padding: 8px;
            border-radius: 6px;
            outline: none;
            box-sizing: border-box;
        }

        .infra-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        .zone {
            background-color: rgba(15, 23, 42, 0.4);
            border: 2px dashed #334155;
            border-radius: 10px;
            padding: 15px;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .zone.local-zone { border-color: #475569; }
        .zone.remote-zone { border-color: var(--accent-purple); }

        .zone-header {
            font-size: 0.8rem;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
        }

        .node {
            background-color: var(--node-bg);
            border: 1px solid #334155;
            border-radius: 8px;
            padding: 12px;
            position: relative;
            transition: all 0.2s ease;
        }

        .node.drag-over {
            border-color: var(--accent-blue);
            background-color: #1e3a8a;
        }

        .node.occupied {
            border-color: var(--accent-green);
            background-color: #064e3b;
        }

        .node-name {
            font-weight: 600;
            font-size: 0.9rem;
            margin-bottom: 4px;
        }

        .node-meta {
            font-size: 0.75rem;
            color: var(--text-muted);
            display: flex;
            gap: 8px;
        }

        .badge {
            background-color: #334155;
            color: #e2e8f0;
            padding: 2px 6px;
            border-radius: 4px;
            font-weight: 600;
        }

        .copy-tag {
            margin-top: 8px;
            background: #10b981;
            font-size: 0.75rem;
            padding: 4px;
            border-radius: 4px;
            text-align: center;
            font-weight: bold;
        }

        .scorecard-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            background: rgba(15, 23, 42, 0.6);
            padding: 10px;
            border-radius: 8px;
            border: 1px solid #1e293b;
        }

        .score-box {
            text-align: center;
            padding: 8px;
            background: var(--bg-dark);
            border-radius: 6px;
            border: 1px solid #334155;
        }

        .score-val {
            font-size: 1.2rem;
            font-weight: bold;
            color: var(--accent-blue);
            margin-top: 4px;
        }

        .score-box.pass { border-color: var(--accent-green); }
        .score-box.pass .score-val { color: var(--accent-green); }

        .terminal-log {
            background-color: var(--bg-dark);
            border: 1px solid #1e293b;
            border-radius: 6px;
            padding: 10px;
            font-family: monospace;
            font-size: 0.8rem;
            height: 150px;
            overflow-y: auto;
            color: #34d399;
        }

        .action-btn {
            background-color: var(--accent-blue);
            color: var(--bg-dark);
            border: none;
            padding: 12px;
            border-radius: 6px;
            font-weight: 700;
            cursor: pointer;
            transition: opacity 0.2s;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 0.05em;
        }

        .action-btn:hover { opacity: 0.9; }

        .modal-overlay {
            display: none;
            position: fixed;
            top:0; left:0; width:100%; height:100%;
            background: rgba(7, 10, 19, 0.9);
            z-index: 100;
            justify-content: center;
            align-items: center;
        }

        .modal-card {
            background-color: var(--panel-bg);
            border: 2px solid #334155;
            border-radius: 12px;
            max-width: 650px;
            width: 90%;
            padding: 30px;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
        }

        .modal-header {
            font-size: 1.4rem;
            font-weight: bold;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .modal-body {
            font-size: 0.95rem;
            line-height: 1.6;
            color: #cbd5e1;
            margin-bottom: 20px;
        }

        .modal-close {
            background-color: var(--accent-blue);
            color: var(--bg-dark);
            border: none; padding: 10px 20px;
            border-radius: 6px; font-weight: bold; cursor: pointer;
        }
    </style>
</head>
<body>

    <div class="lab-wrapper">
        
        <header>
            <div class="header-info">
                <h1>Enterprise Data Protection Resiliency Lab</h1>
                <p>Interactive 3-2-1 Compliance Sandbox & Disaster Drill Engine</p>
            </div>
            <div>
                <span class="badge" style="background-color: #2e1065; color: #c084fc; padding: 6px 12px; font-size: 0.85rem;">Sandbox Version: 2026.2</span>
            </div>
        </header>

        <div class="workspace-grid">
            
            <div class="panel">
                <div class="panel-title">1. Policy Options & Controls</div>
                
                <div class="setting-control">
                    <label>Data Payload Module (Drag Source)</label>
                    <div style="background: rgba(15,23,42,0.5); padding: 12px; border-radius: 8px; border: 1px dashed #334155; text-align: center;">
                        <div class="data-token" draggable="true" id="source-payload">📦 Production_DB.sql</div>
                    </div>
                </div>

                <div class="setting-control">
                    <label for="setting-immutable">WORM Configuration (Immutable)</label>
                    <select id="setting-immutable">
                        <option value="disabled">Disabled (Standard Modifiable Writes)</option>
                        <option value="enabled">Enabled (Object Lock / Compliance Mode)</option>
                    </select>
                </div>

                <div class="setting-control">
                    <label for="setting-retention">Air-Gap Rotation Frequency</label>
                    <input type="range" id="setting-retention" min="1" max="30" value="7">
                    <div style="display:flex; justify-content:space-between; font-size:0.75rem; color:var(--text-muted);">
                        <span>1 Day</span>
                        <span id="retention-val" style="color:var(--accent-blue)">7 Days rotation</span>
                        <span>30 Days</span>
                    </div>
                </div>

                <div class="setting-control">
                    <label for="setting-crr">Cross-Region Replication (CRR)</label>
                    <select id="setting-crr">
                        <option value="disabled">Disabled (Single Target Region)</option>
                        <option value="enabled">Enabled (Multi-Region Geo-Redundancy)</option>
                    </select>
                </div>

                <div class="setting-control">
                    <label for="setting-mfa">MFA Delete Restriction</label>
                    <select id="setting-mfa">
                        <option value="disabled">Disabled (Root can delete via script)</option>
                        <option value="enabled">Enabled (Requires Hardware Token)</option>
                    </select>
                </div>
            </div>

            <div class="panel" style="gap: 15px;">
                <div class="panel-title">2. Storage Target Topology Infrastructure</div>
                
                <div class="infra-grid">
                    <div class="zone local-zone">
                        <div class="zone-header">HQ Primary Zone (On-Site)</div>
                        
                        <div class="node" data-id="n1" data-media="Disk" data-loc="local">
                            <div class="node-name">SAN Array Tier-0</div>
                            <div class="node-meta"><span class="badge">Media: NVMe SSD</span></div>
                        </div>

                        <div class="node" data-id="n2" data-media="Disk" data-loc="local">
                            <div class="node-name">On-Premises NAS</div>
                            <div class="node-meta"><span class="badge">Media: HDD RAID6</span></div>
                        </div>

                        <div class="node" data-id="n3" data-media="Tape" data-loc="local">
                            <div class="node-name">Local LTO Tape Library</div>
                            <div class="node-meta"><span class="badge">Media: LTO-9 Magnetic</span></div>
                        </div>
                    </div>

                    <div class="zone remote-zone">
                        <div class="zone-header">Isolated Recovery Zone (Off-Site)</div>
                        
                        <div class="node" data-id="n4" data-media="Cloud" data-loc="remote">
                            <div class="node-name">Amazon S3 Standard</div>
                            <div class="node-meta"><span class="badge">Media: Object Storage</span></div>
                        </div>

                        <div class="node" data-id="n5" data-media="Cloud" data-loc="remote">
                            <div class="node-name">AWS Backup S3 Vault</div>
                            <div class="node-meta"><span class="badge">Media: Immutable Object</span></div>
                        </div>

                        <div class="node" data-id="n6" data-media="Tape" data-loc="remote">
                            <div class="node-name">Deep Vaults (Offsite Tape)</div>
                            <div class="node-meta"><span class="badge">Media: Air-Gapped Tape</span></div>
                        </div>
                    </div>
                </div>

                <div class="scorecard-grid">
                    <div class="score-box" id="card-copies">
                        <div style="font-size:0.75rem; color:var(--text-muted);">COPIES (Min 3)</div>
                        <div class="score-val" id="val-copies">0</div>
                    </div>
                    <div class="score-box" id="card-media">
                        <div style="font-size:0.75rem; color:var(--text-muted);">MEDIA TYPES (Min 2)</div>
                        <div class="score-val" id="val-media">0</div>
                    </div>
                    <div class="score-box" id="card-offsite">
                        <div style="font-size:0.75rem; color:var(--text-muted);">OFF-SITE (Min 1)</div>
                        <div class="score-val" id="val-offsite">0</div>
                    </div>
                </div>
            </div>

            <div class="panel">
                <div class="panel-title">3. Threat Matrix Engine</div>
                
                <div class="setting-control">
                    <label for="setting-threat">Inject Disaster Attack Vector</label>
                    <select id="setting-threat">
                        <option value="ransomware">LockBit Ransomware (Lateral Propagation)</option>
                        <option value="flood">Catastrophic Datacenter Flash Flood</option>
                        <option value="insider">Malicious Insider (Credential Leak Event)</option>
                        <option value="regional">AWS Regional Outage (US-EAST-1 Failure)</option> </select>
                </div>

                <div class="setting-control">
                    <label>System Live Execution Stream</label>
                    <div class="terminal-log" id="log-stream">> Infrastructure online. Mount payload to map topology...</div>
                </div>

                <button class="action-btn" id="btn-simulate">Fire Disaster Simulation Drill</button>
                
                <button class="action-btn" id="btn-reset" style="background-color:#334155; color:white;">Clear Infrastructure Grid</button>
            </div>

        </div>
    </div>

    <div class="modal-overlay" id="drill-modal">
        <div class="modal-card">
            <div class="modal-header" id="m-header">Drill Execution Completed</div>
            <div class="modal-body" id="m-body">Simulation results loading...</div>
            <div style="text-align: right;">
                <button class="modal-close" onclick="closeDrillModal()">Acknowledge & Re-architect</button>
            </div>
        </div>
    </div>

    <script>
        const infrastructureState = {};

        const payloadToken = document.getElementById('source-payload');
        const storageNodes = document.querySelectorAll('.node');
        const retentionSlider = document.getElementById('setting-retention');
        const retentionVal = document.getElementById('retention-val');
        const logStream = document.getElementById('log-stream');
        const btnSimulate = document.getElementById('btn-simulate');
        const btnReset = document.getElementById('btn-reset');
        const optImmutable = document.getElementById('setting-immutable');
        const optCrr = document.getElementById('setting-crr');
        const optMfa = document.getElementById('setting-mfa');
        const optThreat = document.getElementById('setting-threat');

        retentionSlider.addEventListener('input', (e) => {
            retentionVal.innerText = `${e.target.value} Days rotation`;
            writeLog(`System: Modified rotational gap window threshold to ${e.target.value} days.`);
        });

        optImmutable.addEventListener('change', (e) => writeLog(`Policy: Immutable storage status set to [${e.target.value.toUpperCase()}].`));
        optCrr.addEventListener('change', (e) => write
